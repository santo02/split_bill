            case "travel":
                return "🚗";
            case "shopping":
                return "🛒";
            default:
                return "💵";
        }
    }

    private decimal CalculateIndividualShareAmount(Item item, ItemAssignee assign)
    {
        if (assign.InputType == AssigneeInputType.Nominal)
        {
            return assign.NominalAmount;
        }
        else
        {
            var ratioAssignees = item.Assignees.Where(a => a.InputType == AssigneeInputType.Ratio).ToList();
            var totalRatio = ratioAssignees.Sum(a => a.ShareRatio);
            
            decimal nominalSum = item.Assignees.Where(a => a.InputType == AssigneeInputType.Nominal).Sum(a => a.NominalAmount);
            decimal remaining = Math.Max(0, item.Price - nominalSum);

            if (totalRatio > 0)
            {
                return Math.Round(remaining * (assign.ShareRatio / totalRatio), 0);
            }
            return 0m;
        }
    }
