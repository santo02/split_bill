    private void OnExpenseAmountChanged(ChangeEventArgs e)
    {
        expenseAmountString = e.Value?.ToString() ?? "";
        RecalculateManualDefaults();
    }

    private void RecalculateManualDefaults()
    {
        if (expenseSplitMode == "Manual" && expenseParticipantIds.Any())
        {
            decimal amt = ParseDecimal(expenseAmountString);
            if (amt <= 0) return;

            // Calculate how much is already assigned
            decimal alreadyAssigned = 0m;
            int unassignedCount = 0;

            foreach (var pId in expenseParticipantIds)
            {
                if (manualNominalAmounts.TryGetValue(pId, out var val) && val > 0)
                {
                    alreadyAssigned += val;
                }
                else
                {
                    unassignedCount++;
                }
            }

            // Distribute remaining amount evenly among unassigned participants
            decimal remaining = Math.Max(0, amt - alreadyAssigned);
            decimal avg = unassignedCount > 0 ? Math.Round(remaining / unassignedCount, 0) : 0m;

            foreach (var pId in expenseParticipantIds)
            {
                if (!manualNominalAmounts.ContainsKey(pId) || manualNominalAmounts[pId] == 0)
                {
                    manualNominalAmounts[pId] = avg;
                }
            }
        }
    }

    /// <summary>
    /// Returns "ok" if shares match total, "under" if shares < total, "over" if shares > total
    /// </summary>
    private string sharesBalanceStatus
    {
        get
        {
            if (!showAddExpenseModal) return "ok";
            decimal total = ParseDecimal(expenseAmountString);
            if (total <= 0) return "ok"; // No amount entered yet

            decimal sharesSum;
            if (expenseSplitMode == "Equal")
            {
                int pCount = expenseParticipantIds.Count;
                if (pCount == 0) return "ok";
                decimal perPerson = Math.Round(total / pCount, 0);
                sharesSum = perPerson * pCount;
            }
            else
            {
                sharesSum = manualNominalAmounts.Values.Sum();
            }

            decimal diff = total - sharesSum;
            if (Math.Abs(diff) <= 1m) return "ok"; // Allow 1 rupiah rounding tolerance
            return diff > 0 ? "under" : "over";
        }
    }

    private decimal sharesDifference
    {
        get
        {
            decimal total = ParseDecimal(expenseAmountString);
            decimal sharesSum;
            if (expenseSplitMode == "Equal")
            {
                int pCount = expenseParticipantIds.Count;
                if (pCount == 0) return 0m;
                decimal perPerson = Math.Round(total / pCount, 0);
                sharesSum = perPerson * pCount;
            }
            else
            {
                sharesSum = manualNominalAmounts.Values.Sum();
            }
            return Math.Abs(total - sharesSum);
        }
    }

    private decimal calculatedPersonPays
    {
        get
        {
            decimal amount = ParseDecimal(expenseAmountString);
            if (expenseSplitMode == "Equal")
            {
                int pCount = expenseParticipantIds.Count;
                return pCount > 0 ? Math.Round(amount / pCount, 0) : 0m;
            }
            else
            {
                return manualNominalAmounts.Values.Sum();
            }
        }
    }

    private void ToggleExpenseParticipant(int id)
    {
        if (expenseParticipantIds.Contains(id))
        {
            expenseParticipantIds.Remove(id);
            manualNominalAmounts.Remove(id);
        }
        else
        {
            expenseParticipantIds.Add(id);
            RecalculateManualDefaults();
        }
    }

    private void ToggleSelectAllParticipants()
    {
        if (bill == null) return;
        var activePs = bill.Participants.Where(pt => !pt.IsDeleted).Select(pt => pt.Id).ToList();
        
        if (expenseParticipantIds.Count == activePs.Count)
        {
            expenseParticipantIds.Clear();
            manualNominalAmounts.Clear();
        }
        else
        {
            foreach (var id in activePs)
            {
                expenseParticipantIds.Add(id);
            }
            RecalculateManualDefaults();
        }
    }

