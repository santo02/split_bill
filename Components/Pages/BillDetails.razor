    private async Task SaveExpense()
    {
        decimal amount = ParseDecimal(expenseAmountString);
        if (string.IsNullOrWhiteSpace(expenseName) || amount <= 0 || bill == null) return;

        // Validate shares balance before saving
        if (sharesBalanceStatus != "ok") return;

        var item = new Item
        {
            BillId = bill.Id,
            Name = expenseName.Trim(),
            Price = amount,
            Category = expenseCategory,
            Date = expenseDate,
            FrontedByParticipantId = expensePaidById,
            Notes = expenseNotes.Trim(),
            TaxType = ChargeType.Percentage,
            TaxValue = 0,
            ServiceChargeType = ChargeType.Percentage,
            ServiceChargeValue = 0
        };

        Db.Items.Add(item);
        await Db.SaveChangesAsync(); // save item first to get its ID

        // Add assignees
        foreach (var pId in expenseParticipantIds)
        {
            var assignee = new ItemAssignee
            {
                ItemId = item.Id,
                ParticipantId = pId,
                InputType = expenseSplitMode == "Manual" ? AssigneeInputType.Nominal : AssigneeInputType.Ratio,
                ShareRatio = 1.0m,
                NominalAmount = expenseSplitMode == "Manual" ? manualNominalAmounts.GetValueOrDefault(pId) : 0m
            };
            Db.ItemAssignees.Add(assignee);
        }

        await Db.SaveChangesAsync();
        showAddExpenseModal = false;
        await RefreshData();
    }

