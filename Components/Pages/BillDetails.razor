                                    </div>
                                </div>
                            }
                            else if (sharesBalanceStatus == "over")
                            {
                                <div class="bg-amber-50 border border-amber-200 rounded-xl p-2.5 flex items-start gap-2">
                                    <svg class="w-4 h-4 text-amber-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
                                    </svg>
                                    <div>
                                        <span class="text-[10px] font-bold text-amber-700 block">Porsi melebihi total</span>
                                        <span class="text-[9px] text-amber-500">Kelebihan Rp @sharesDifference.ToString("N0") dari Rp @ParseDecimal(expenseAmountString).ToString("N0")</span>
                                    </div>
                                </div>
                            }

                            @if (expenseSplitMode == "Manual")
                            {
                                <div class="space-y-2 pt-2 border-t border-slate-100">
                                    @foreach (var pId in expenseParticipantIds)
                                    {
                                        var p = bill.Participants.FirstOrDefault(pt => pt.Id == pId);
                                        if (p != null)
                                        {
                                            var nominalStr = GetManualNominalString(pId);
                                            <div class="flex items-center justify-between text-xs gap-3">
                                                <span class="font-semibold text-slate-600">@p.Name</span>
                                                <div class="flex items-center gap-1 bg-white border border-slate-200 rounded-lg px-2 py-1">
                                                    <span class="text-[10px] text-slate-400">Rp</span>
                                                    <input type="text" value="@nominalStr" oninput="formatCurrencyOnInput(this)" @onchange="(e) => OnManualNominalChanged(pId, e.Value)" class="w-20 font-mono text-slate-700 focus:outline-none text-right font-bold" />
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>
                            }
                        </div>

                        <textarea @bind="expenseNotes" rows="2" class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10 text-xs resize-none transition-all" placeholder="Catatan tambahan (opsional)"></textarea>
                    </div>
                </div>

                <button @onclick="SaveExpense" class="w-full mt-4 py-3.5 @(sharesBalanceStatus == "ok" ? "bg-blue-600 hover:bg-blue-700" : "bg-slate-300 cursor-not-allowed") text-white font-extrabold rounded-xl text-xs tracking-wider transition-all duration-200 transform @(sharesBalanceStatus == "ok" ? "active:scale-95" : "") flex items-center justify-center gap-1.5 shadow-sm" disabled="@(sharesBalanceStatus != "ok")">
                    @if (sharesBalanceStatus != "ok")
                    {
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
                        </svg>
                        <span>Perbaiki Porsi Terlebih Dahulu</span>
                    }
                    else
                    {
                        <span>Simpan Pengeluaran</span>
                    }
                </button>
            </div>
        </div>
    }

    <!-- B. MODAL: ADD MEMBER -->
    @if (showAddMemberModal)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/60 backdrop-blur-sm p-4 animate-fade-in">
            <div class="bg-white w-full max-w-md rounded-2xl border border-slate-200 shadow-2xl p-6 space-y-4">
                <div class="flex items-center justify-between border-b border-slate-100 pb-3">
                    <h3 class="text-xs font-bold text-slate-800 uppercase tracking-wider">Tambah Anggota</h3>
                    <button @onclick="CloseAddMemberModal" class="text-slate-400 hover:text-slate-700">✕</button>
                </div>

                <div class="space-y-3">
                    <div class="space-y-1">
                        <label class="block text-[8px] font-bold text-slate-400 uppercase tracking-wider">Nama Lengkap</label>
                        <input @bind="newMemberName" class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 text-xs font-semibold focus:outline-none focus:border-blue-600 focus:ring-2 focus:ring-blue-500/10 transition-all" placeholder="Contoh: David Chen" />
                    </div>
                </div>

                <button @onclick="SaveMember" class="w-full py-3 bg-blue-600 hover:bg-blue-700 text-white font-extrabold rounded-xl text-xs tracking-wider transition-all transform active:scale-95 shadow-sm">
                    Simpan Anggota
                </button>
            </div>
        </div>
    }

    <!-- C. MODAL: EDIT GROUP INFO -->
    @if (showEditGroupModal)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/60 backdrop-blur-sm p-4 animate-fade-in">
            <div class="bg-white w-full max-w-md rounded-2xl border border-slate-200 shadow-2xl p-6 space-y-4">
                <div class="flex items-center justify-between border-b border-slate-100 pb-3">
                    <h3 class="text-xs font-bold text-slate-800 uppercase tracking-wider">Edit Detail Grup</h3>
                    <button @onclick="CloseEditGroupModal" class="text-slate-400 hover:text-slate-700">✕</button>
                </div>

                <div class="space-y-3">
                    <div class="space-y-1">
                        <label class="block text-[8px] font-bold text-slate-400 uppercase tracking-wider">Nama Acara</label>
                        <input @bind="editEventName" class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 text-xs font-semibold focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10 transition-all" />
                    </div>
                    <div class="space-y-1">
                        <label class="block text-[8px] font-bold text-slate-400 uppercase tracking-wider">Deskripsi</label>
                        <textarea @bind="editDescription" rows="2" class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 text-xs font-semibold focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10 resize-none transition-all"></textarea>
                    </div>
                    <div class="grid grid-cols-2 gap-3">
                        <div class="space-y-1">
                            <label class="block text-[8px] font-bold text-slate-400 uppercase tracking-wider">Mulai</label>
                            <input type="date" @bind="editStartDate" class="w-full px-2 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 text-xs font-semibold focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10 transition-all" />
                        </div>
                        <div class="space-y-1">
                            <label class="block text-[8px] font-bold text-slate-400 uppercase tracking-wider">Selesai</label>
                            <input type="date" @bind="editEndDate" class="w-full px-2 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 text-xs font-semibold focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10 transition-all" />
                        </div>
                    </div>
                    <div class="space-y-1">
                        <label class="block text-[8px] font-bold text-slate-400 uppercase tracking-wider">Status</label>
                        <select @bind="editStatus" class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 text-xs font-semibold focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10 transition-all">
                            <option value="ONGOING">ONGOING</option>
                            <option value="COMPLETED">COMPLETED</option>
                            <option value="ARCHIVED">ARCHIVED</option>
                        </select>
                    </div>
                </div>

                <button @onclick="SaveGroupDetails" class="w-full py-3 bg-blue-600 hover:bg-blue-700 text-white font-extrabold rounded-xl text-xs tracking-wider transition-all transform active:scale-95 shadow-sm">
                    Simpan Perubahan
                </button>
            </div>
        </div>
    }

    <!-- D. MODAL: ADD PAYMENT (SETTLE UP) -->
    @if (showAddPaymentModal)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/60 backdrop-blur-sm p-4 animate-fade-in">
            <div class="bg-white w-full max-w-md rounded-2xl border border-slate-200 shadow-2xl p-6 space-y-4">
                <div class="flex items-center justify-between border-b border-slate-100 pb-3">
                    <h3 class="text-xs font-bold text-slate-800 uppercase tracking-wider">Catat Pembayaran</h3>
                    <button @onclick="CloseAddPaymentModal" class="text-slate-400 hover:text-slate-700">✕</button>
                </div>

                <div class="bg-emerald-50 rounded-xl p-4 border border-emerald-100 flex items-center gap-3">
                    <span class="text-2xl font-black text-emerald-600">Rp</span>
                    <input type="text" @bind="paymentAmountString" oninput="formatCurrencyOnInput(this)" class="w-full bg-transparent border-none focus:outline-none text-2xl font-black text-emerald-950 font-mono" placeholder="0" />
                </div>

                <div class="space-y-3">
                    <div class="space-y-1">
                        <label class="block text-[8px] font-bold text-slate-400 uppercase tracking-wider">Anggota yang membayar ke kasir</label>
                        <select @bind="paymentParticipantId" class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 text-xs font-semibold focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10 transition-all">
                            @foreach (var p in bill.Participants.Where(pt => !pt.IsDeleted))
                            {
                                <option value="@p.Id">@p.Name</option>
                            }
                        </select>
                    </div>
                </div>

                <button @onclick="SavePayment" class="w-full py-3 bg-emerald-600 hover:bg-emerald-700 text-white font-extrabold rounded-xl text-xs tracking-wider transition-all transform active:scale-95 shadow-sm">
                    Simpan Pembayaran
                </button>
            </div>
        </div>
    }

    <!-- Script for input formatting -->
    <script>
        function formatCurrencyOnInput(el) {
            let val = el.value.replace(/\D/g, '');
            el.value = val ? parseInt(val, 10).toLocaleString('id-ID') : '';
        }
    </script>

    <style>
        .scrollbar-thin::-webkit-scrollbar {
            height: 4px;
        }
        .scrollbar-thin::-webkit-scrollbar-track {
            background: #f1f5f9;
            border-radius: 4px;
        }
        .scrollbar-thin::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        .scrollbar-thin::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
        @@keyframes fade-in {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in {
            animation: fade-in 0.3s ease-out;
        }
    </style>
}

@code {
    [Parameter]
    public string Uuid { get; set; } = string.Empty;

    private Bill? bill;
    private SettlementResult settlement = new();
    private bool loading = true;
    private bool isCreator = false;
    private bool copied = false;

    // Tabs
    private string activeTab = "Expenses"; // Expenses, Members, Summary, Settlements
    private string selectedCategoryFilter = "All";
    private string searchQuery = "";

    // Modals
    private bool showAddExpenseModal = false;
    private bool showAddMemberModal = false;
    private bool showEditGroupModal = false;
    private bool showAddPaymentModal = false;

    // Form fields - Add Expense
    private string expenseAmountString = "";
    private string expenseName = "";
    private string expenseCategory = "Food";
    private DateTime expenseDate = DateTime.Today;
    private int expensePaidById = 0;
    private HashSet<int> expenseParticipantIds = new();
    private string expenseSplitMode = "Equal"; // Equal, Manual
    private Dictionary<int, decimal> manualNominalAmounts = new();
    private string expenseNotes = "";

    // Form fields - Add Member
    private string newMemberName = "";

    // Form fields - Edit Group Info
    private string editEventName = "";
    private string editDescription = "";
    private DateTime? editStartDate;
    private DateTime? editEndDate;
    private string editStatus = "ONGOING";

    // Form fields - Add Payment
    private int paymentParticipantId = 0;
    private string paymentAmountString = "";

    private Dictionary<int, bool> expandedItems = new();

    private void ToggleItemExpand(int itemId)
    {
        expandedItems[itemId] = !expandedItems.GetValueOrDefault(itemId);
    }

    private decimal ParseDecimal(string? formattedStr)
    {
        if (string.IsNullOrWhiteSpace(formattedStr)) return 0;
        string clean = new string(formattedStr.Where(char.IsDigit).ToArray());
        decimal.TryParse(clean, out decimal result);
        return result;
    }

    private List<Item> GetFilteredItems()
    {
        if (bill == null) return new List<Item>();
        var filtered = bill.Items.Where(i => !i.IsDeleted);
        if (selectedCategoryFilter != "All")
        {
            filtered = filtered.Where(i => i.Category.Equals(selectedCategoryFilter, StringComparison.OrdinalIgnoreCase));
        }
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            filtered = filtered.Where(i => i.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));
        }
        return filtered.OrderByDescending(i => i.Id).ToList();
    }

    private List<ParticipantSummary> GetFilteredSummaries()
    {
        return settlement.ParticipantSummaries
            .Where(s => string.IsNullOrWhiteSpace(searchQuery) || 
                        s.ParticipantName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private List<Payer> GetFilteredPayers()
    {
        if (bill == null) return new List<Payer>();
        var filtered = bill.Payers.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            filtered = filtered.Where(p => p.Participant.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));
        }
        return filtered.ToList();
    }

    private List<(string text, string time, string icon, string color)> GetRecentActivities()
    {
        var logs = new List<(string text, string time, string icon, string color)>();
        if (bill == null) return logs;
        
        logs.Add(("Grup perjalanan dibuat", "Mulai", "📂", "bg-slate-100 text-slate-600"));

        foreach (var p in bill.Participants.Where(pt => !pt.IsDeleted).Take(3))
        {
            logs.Insert(0, ($"{p.Name} baru saja bergabung", "Baru", "👥", "bg-blue-50 text-blue-600"));
        }
        
        foreach (var item in bill.Items.Where(it => !it.IsDeleted).Take(3))
        {
            var pName = bill.Participants.FirstOrDefault(p => p.Id == item.FrontedByParticipantId)?.Name ?? "Anggota";
            logs.Insert(0, ($"{pName} menambahkan pengeluaran {item.Name}", "Baru", "💵", "bg-emerald-50 text-emerald-600"));
        }
        
        return logs.Take(4).ToList();
    }

    protected override async Task OnParametersSetAsync()
    {
        await RefreshData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                if (bill != null)
                {
                    var savedToken = await JS.InvokeAsync<string>("localStorage.getItem", $"bill_creator_token_{Uuid}");
                    isCreator = !string.IsNullOrEmpty(savedToken) && savedToken == bill.CreatorToken;
                    StateHasChanged();
                }
            }
            catch
            {
                // Fallback
            }
        }
    }

    private async Task RefreshData()
    {
        loading = true;

        bill = await Db.Bills
            .Include(b => b.Participants)
            .Include(b => b.Payers)
                .ThenInclude(p => p.Participant)
            .Include(b => b.Items)
                .ThenInclude(i => i.Assignees)
            .FirstOrDefaultAsync(b => b.Uuid == Uuid);

        if (bill != null)
        {
            settlement = Settlement.CalculateSettlement(bill);
            
            // Auto initialize forms if not dirty
            if (expensePaidById == 0 && bill.Participants.Any(p => !p.IsDeleted))
            {
                var firstParticipant = bill.Participants.FirstOrDefault(p => !p.IsDeleted);
                if (firstParticipant != null)
                {
                    expensePaidById = firstParticipant.Id;
                }
            }
        }

        loading = false;
    }

