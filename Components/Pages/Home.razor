<!-- ===== MODAL: CATAT PENGELUARAN BARU ===== -->
@if (showModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/60 backdrop-blur-sm p-4 animate-fade-in" @onclick="HandleBackdropClick">
        <div class="bg-white w-full max-w-lg rounded-2xl border border-slate-200 shadow-2xl overflow-hidden animate-slide-up" @onclick:stopPropagation>
            <!-- Modal Header -->
            <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
                <div>
                    <h2 class="text-base font-extrabold text-slate-800 tracking-tight">Catat Pengeluaran Baru</h2>
                    <p class="text-xs text-slate-400 mt-0.5">Tentukan perjalanan atau acara Anda untuk mulai membagi biaya.</p>
                </div>
                <button @onclick="CloseModal" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-slate-100 text-slate-400 hover:text-slate-600 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <!-- Modal Body -->
            <div class="px-6 py-5">
                <EditForm Model="@newBill" OnValidSubmit="CreateBill" FormName="createBillForm">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-red-500 text-xs mb-4 font-semibold" />

                    <div class="space-y-5">
                        <!-- Event Name -->
                        <div class="space-y-1.5">
                            <label for="eventName" class="block text-xs font-bold uppercase tracking-wider text-slate-500">Nama Acara / Perjalanan</label>
                            <input id="eventName" @bind="newBill.EventName" class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-sm" placeholder="Contoh: Weekend in Paris" required />
                        </div>

                        <!-- Description -->
                        <div class="space-y-1.5">
                            <label for="description" class="block text-xs font-bold uppercase tracking-wider text-slate-500">Deskripsi</label>
                            <textarea id="description" @bind="newBill.Description" rows="3" class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-sm resize-none" placeholder="Untuk apa sesi ini?"></textarea>
                        </div>

                        <!-- Dates Grid -->
                        <div class="grid grid-cols-2 gap-4">
                            <div class="space-y-1.5">
                                <label for="startDate" class="block text-xs font-bold uppercase tracking-wider text-slate-500">Tanggal Mulai</label>
                                <input id="startDate" type="date" @bind="newBill.StartDate" class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-slate-800 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                            </div>
                            <div class="space-y-1.5">
                                <label for="endDate" class="block text-xs font-bold uppercase tracking-wider text-slate-500">Tanggal Selesai</label>
                                <input id="endDate" type="date" @bind="newBill.EndDate" class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-slate-800 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                            </div>
                        </div>
                    </div>

                    <!-- Submit -->
                    <button type="submit" class="w-full mt-6 py-3.5 px-6 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm shadow-lg shadow-blue-500/15 transition-all duration-200 active:scale-[0.98] flex items-center justify-center gap-2">
                        <span>Buat Sesi &amp; Mulai</span>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                        </svg>
                    </button>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private BillModel newBill = new();
    private bool showModal = false;

    private void OpenModal()
    {
        newBill = new BillModel();
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private void HandleBackdropClick()
    {
        CloseModal();
    }

    private async Task CreateBill()
    {
        string uuid = Guid.NewGuid().ToString("N").Substring(0, 8);
        string creatorToken = Guid.NewGuid().ToString("D");

        var bill = new Bill
        {
            Uuid = uuid,
            EventName = newBill.EventName,
            Description = string.IsNullOrWhiteSpace(newBill.Description) ? "Perjalanan bersama tim." : newBill.Description,
            StartDate = newBill.StartDate,
            EndDate = newBill.EndDate,
            CreatedAt = DateTime.UtcNow,
            TaxType = ChargeType.Percentage,
            TaxValue = 0,
            ServiceChargeType = ChargeType.Percentage,
            ServiceChargeValue = 0,
            CreatorToken = creatorToken,
            IsDeleted = false
        };

        Db.Bills.Add(bill);
        await Db.SaveChangesAsync();

        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", $"bill_creator_token_{uuid}", creatorToken);
        }
        catch { }

        Navigation.NavigateTo($"/bill/{uuid}");
    }

    public class BillModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Nama acara wajib diisi")]
        [System.ComponentModel.DataAnnotations.StringLength(100, ErrorMessage = "Nama terlalu panjang")]
        public string EventName { get; set; } = "";

        public string Description { get; set; } = "";

        public DateTime StartDate { get; set; } = DateTime.Today;
        public DateTime EndDate { get; set; } = DateTime.Today.AddDays(3);
    }
}

<style>
